{
  "name": "retro-launcher",
  "version": "1.0.0",
  "description": "A sleek game launcher for PS1, PS2, PS3, Xbox, and Xbox 360",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64",
    "build-portable": "electron-builder --win portable"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.retrolauncher.app",
    "productName": "RetroLauncher",
    "directories": { "output": "dist" },
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }],
      "icon": "assets/icon.ico"
    },
    "files": ["src/**/*", "assets/**/*", "games.json"],
    "extraResources": [{ "from": "artwork", "to": "artwork" }]
  }
}
